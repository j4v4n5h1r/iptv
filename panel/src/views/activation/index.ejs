<div class="page-header">
  <h1 class="page-title"><span class="prompt">$</span> activation-codes</h1>
</div>

<div class="stats-row">
  <div class="stat-card">
    <div class="stat-label">Total</div>
    <div class="stat-value"><%= codes.length %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Unused</div>
    <div class="stat-value green"><%= codes.filter(c => c.status === 'unused').length %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Used</div>
    <div class="stat-value red"><%= codes.filter(c => c.status === 'used').length %></div>
  </div>
</div>

<!-- Generate form -->
<div class="card mb-20">
  <div class="card-header">
    <span class="card-title">// Generate New Activation Code</span>
  </div>
  <div class="card-body">
    <form method="POST" action="/activation-codes">

      <div class="form-group">
        <label class="form-label"><span class="prompt">--</span> App User <span style="color:var(--red);font-size:13px;">*zorunlu</span></label>
        <select name="mac_user_id" id="userSelect" class="form-control" onchange="onUserChange(this)" required>
          <option value="">— Kullanıcı seçin —</option>
          <% macUsers.forEach(u => { %>
            <option value="<%= u.id %>" data-keys="<%= (u.all_app_keys || []).join(',') %>">
              <%= u.title %> (<%= (u.all_app_keys || [u.app_key]).length %> TV)
            </option>
          <% }) %>
        </select>
      </div>

      <!-- Allowed App Keys — auto filled from selected user -->
      <div class="form-group" id="allowedKeysGroup" style="display:none;">
        <label class="form-label"><span class="prompt">--</span> Authorized App Keys</label>
        <div id="autoKeyPreview" style="padding:10px 12px; background:var(--bg-card); border:1px solid var(--border); border-radius:6px;"></div>
        <div class="form-hint">Bu kullanıcının TV'leri otomatik eklendi. Kod yalnızca bu cihazlarda çalışır.</div>
      </div>

      <button type="submit" id="generateBtn" class="btn btn-primary" disabled style="opacity:0.4; cursor:not-allowed;">
        <i class="fa fa-bolt"></i> Generate
      </button>
    </form>
  </div>
</div>

<!-- List -->
<div class="card">
  <div class="card-header">
    <span class="card-title">// Codes List</span>
  </div>
  <div class="card-body">
    <% if (codes.length === 0) { %>
      <div class="empty-state">
        <span class="ei"><i class="fa fa-key"></i></span>
        <p>No activation codes yet. Generate some above.</p>
      </div>
    <% } else { %>
      <div class="table-wrapper">
        <table id="actTable" class="display" style="width:100%">
          <thead>
            <tr>
              <th>#</th>
              <th>Activation Code</th>
              <th>Status</th>
              <th>Allowed Keys</th>
              <th>Used By</th>
              <th>Server</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% codes.forEach((c, i) => { %>
              <tr>
                <td class="td-code"><%= i + 1 %></td>
                <td class="td-code" style="color:var(--green); letter-spacing:1px; font-size:15px">
                  <b><%= c.code %></b>
                  <button class="btn-copy" title="Copy code" onclick="copyCode(this, '<%= c.code %>')">
                    <i class="fa fa-copy"></i>
                  </button>
                </td>
                <td><span class="badge badge-<%= c.status %>"><%= c.status %></span></td>
                <td class="td-code" style="font-size:13px; color:var(--text-muted);">
                  <% if (c.allowed_keys && c.allowed_keys.length > 0) { %>
                    <% c.allowed_keys.forEach(k => { %>
                      <div style="color:var(--cyan); letter-spacing:.5px;"><%= k %></div>
                    <% }) %>
                  <% } else { %>
                    <span style="color:var(--text-muted)">herkese açık</span>
                  <% } %>
                </td>
                <td class="td-code"><%= c.used_by || '—' %></td>
                <td class="td-code"><%= c.server_title || '—' %></td>
                <td class="td-code"><%= c.created_at ? c.created_at.split('T')[0] : '—' %></td>
                <td>
                  <% if (c.status === 'used') { %>
                    <form method="POST" action="/activation-codes/<%= c.id %>/reset" style="display:inline;">
                      <button type="submit" class="btn btn-outline btn-sm"><i class="fa fa-rotate-left"></i> Reset</button>
                    </form>
                    &nbsp;
                  <% } %>
                  <button class="btn btn-danger btn-sm" onclick="confirmDelete('/activation-codes/<%= c.id %>?_method=DELETE')">
                    <i class="fa fa-trash"></i>
                  </button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<style>
.btn-copy {
  background: none; border: none; color: var(--text-muted); cursor: pointer;
  padding: 2px 5px; margin-left: 6px; border-radius: 3px; font-size: 14px;
  transition: color .15s; vertical-align: middle;
}
.btn-copy:hover { color: var(--green); }
.btn-copy.copied { color: var(--green); }
.key-row { display:flex; gap:8px; align-items:center; }
.key-row input { flex:1; font-family:monospace; letter-spacing:1.5px; text-transform:uppercase; }
</style>

<script>
$(document).ready(function() {
  $('#actTable').DataTable({
    lengthMenu: [[10, 25, 50, -1], [10, 25, 50, 'All']],
    order: [[6, 'desc']],
    columnDefs: [{ orderable: false, targets: 7 }],
    language: { search: '<i class="fa fa-search"></i>', searchPlaceholder: 'Search codes...' }
  });
});

function onUserChange(sel) {
  const group = document.getElementById('allowedKeysGroup');
  const preview = document.getElementById('autoKeyPreview');
  const btn = document.getElementById('generateBtn');
  const keys = sel.value ? (sel.selectedOptions[0].dataset.keys || '').split(',').filter(k => k) : [];

  if (sel.value) {
    group.style.display = 'block';
    preview.innerHTML = keys.length > 0
      ? keys.map(k => `<div style="color:var(--cyan);font-family:monospace;letter-spacing:1px;">${k}</div>`).join('')
      : '<div style="color:var(--text-muted);font-size:13px;">Bu kullanıcıya henüz app key eklenmemiş.</div>';
    btn.disabled = false;
    btn.style.opacity = '1';
    btn.style.cursor = 'pointer';
  } else {
    group.style.display = 'none';
    btn.disabled = true;
    btn.style.opacity = '0.4';
    btn.style.cursor = 'not-allowed';
  }
}

function addKeyRow(value) {
  const list = document.getElementById('appKeyList');
  const row = document.createElement('div');
  row.className = 'key-row';
  row.innerHTML = `
    <input type="text" name="allowed_app_keys[]" class="form-control"
      placeholder="VNUX-XXXX-XXXX" value="${value || ''}"
      oninput="this.value=this.value.toUpperCase()">
    <button type="button" class="btn btn-danger btn-sm" onclick="this.parentElement.remove()">
      <i class="fa fa-trash"></i>
    </button>`;
  list.appendChild(row);
  row.querySelector('input').focus();
}

function copyCode(btn, code) {
  navigator.clipboard.writeText(code).then(() => {
    const icon = btn.querySelector('i');
    icon.className = 'fa fa-check';
    btn.classList.add('copied');
    setTimeout(() => { icon.className = 'fa fa-copy'; btn.classList.remove('copied'); }, 1500);
  });
}
</script>
