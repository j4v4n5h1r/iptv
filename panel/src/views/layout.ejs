<!DOCTYPE html>
<html lang="en" style="background:#0e001a">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="dark">
  <title><%= typeof title !== 'undefined' ? title : 'IPTV' %> — IPTV Panel</title>
  <!-- Critical: dark bg + full-screen loader before ANY external file loads -->
  <style>
    html,body{background:#0e001a!important;margin:0;padding:0}
    #page-loader{position:fixed;inset:0;z-index:99999;background:#0e001a;display:flex;align-items:center;justify-content:center;transition:opacity .3s ease}
    #page-loader.loader-done{opacity:0;pointer-events:none}
    .loader-inner{position:relative;width:48px;height:48px}
    .loader-ring{position:absolute;inset:0;border-radius:50%;border:2px solid transparent;border-top-color:#e95420;border-right-color:#e95420;animation:lspin .7s linear infinite}
    .loader-ring::after{content:'';position:absolute;inset:5px;border-radius:50%;border:2px solid transparent;border-bottom-color:#39ff14;border-left-color:#39ff14;animation:lspin .5s linear infinite reverse}
    .loader-dot{position:absolute;top:50%;left:50%;width:6px;height:6px;background:#e95420;border-radius:50%;transform:translate(-50%,-50%);box-shadow:0 0 8px #e95420;animation:lpulse .7s ease-in-out infinite alternate}
    @keyframes lspin{to{transform:rotate(360deg)}}
    @keyframes lpulse{to{opacity:.2;transform:translate(-50%,-50%) scale(.5)}}
  </style>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.min.css">
</head>
<body>

<!-- Page loader -->
<div id="page-loader">
  <div class="loader-inner">
    <div class="loader-ring"></div>
    <div class="loader-dot"></div>
  </div>
</div>

<!-- Network background -->
<div id="net-canvas"></div>

<div class="wrapper">

  <!-- SIDEBAR -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-brand">
      <div class="brand-logo">
        <div class="brand-icon"><i class="fa fa-tv"></i></div>
        <div>
          <div class="brand-name">IPTV Panel</div>
        </div>
      </div>
      <div class="brand-sub">Management System</div>
      <div class="brand-prompt">ssh admin@iptv-server</div>
    </div>

    <nav class="sidebar-nav">
      <div class="nav-section">// Overview</div>

      <a href="/dashboard" class="nav-item <%= (typeof path !== 'undefined' && path === '/dashboard') ? 'active' : '' %>">
        <span class="nav-arrow">›</span><i class="ni fa fa-gauge"></i>Dashboard
      </a>

      <div class="nav-section">// Streaming</div>

      <a href="/dns" class="nav-item <%= (typeof path !== 'undefined' && path === '/dns') ? 'active' : '' %>">
        <span class="nav-arrow">›</span><i class="ni fa fa-server"></i>DNS Settings
      </a>
      <a href="/mac-users" class="nav-item <%= (typeof path !== 'undefined' && path.startsWith('/mac-users')) ? 'active' : '' %>">
        <span class="nav-arrow">›</span><i class="ni fa fa-microchip"></i>MAC Users
      </a>
      <a href="/activation-codes" class="nav-item <%= (typeof path !== 'undefined' && path === '/activation-codes') ? 'active' : '' %>">
        <span class="nav-arrow">›</span><i class="ni fa fa-key"></i>Activation Codes
      </a>
      <a href="/trials" class="nav-item <%= (typeof path !== 'undefined' && path === '/trials') ? 'active' : '' %>">
        <span class="nav-arrow">›</span><i class="ni fa fa-calendar-days"></i>Set Expiration
      </a>

      <div class="nav-section">// App Config</div>

      <a href="/settings/demo" class="nav-item <%= (typeof path !== 'undefined' && path === '/settings/demo') ? 'active' : '' %>">
        <span class="nav-arrow">›</span><i class="ni fa fa-play-circle"></i>Set Demo
      </a>
      <a href="/settings/notification" class="nav-item <%= (typeof path !== 'undefined' && path === '/settings/notification') ? 'active' : '' %>">
        <span class="nav-arrow">›</span><i class="ni fa fa-bell"></i>Set Notification
      </a>
      <a href="/settings/mac-length" class="nav-item <%= (typeof path !== 'undefined' && path === '/settings/mac-length') ? 'active' : '' %>">
        <span class="nav-arrow">›</span><i class="ni fa fa-hashtag"></i>Set MAC Length
      </a>
      <a href="/settings/login-text" class="nav-item <%= (typeof path !== 'undefined' && path === '/settings/login-text') ? 'active' : '' %>">
        <span class="nav-arrow">›</span><i class="ni fa fa-pen-to-square"></i>Login Page Text
      </a>

      <div class="nav-section">// System</div>

      <a href="/settings/update" class="nav-item <%= (typeof path !== 'undefined' && path === '/settings/update') ? 'active' : '' %>">
        <span class="nav-arrow">›</span><i class="ni fa fa-upload"></i>Remote Update
      </a>
      <a href="/settings/license" class="nav-item <%= (typeof path !== 'undefined' && path === '/settings/license') ? 'active' : '' %>">
        <span class="nav-arrow">›</span><i class="ni fa fa-id-badge"></i>License Key
      </a>
      <a href="/settings/credentials" class="nav-item <%= (typeof path !== 'undefined' && path === '/settings/credentials') ? 'active' : '' %>">
        <span class="nav-arrow">›</span><i class="ni fa fa-user-gear"></i>Credentials
      </a>
    </nav>

    <div class="sidebar-footer">
      <div class="online-dot"></div>
      <span>online &nbsp;·&nbsp; v1.0.0</span>
    </div>
  </aside>

  <!-- MAIN -->
  <div class="main-content">

    <nav class="topbar">
      <button class="topbar-toggle" id="sidebarToggle"><i class="fa fa-bars"></i></button>
      <div class="topbar-breadcrumb">
        <span>~</span><span class="bc-sep">/</span>
        <span>iptv-panel</span><span class="bc-sep">/</span>
        <span class="bc-curr"><%= typeof title !== 'undefined' ? title.toLowerCase().replace(/ /g,'-') : '' %></span>
      </div>
      <div class="topbar-right">
        <div class="topbar-user">logged in as <b><%= typeof admin !== 'undefined' ? admin : '' %></b></div>
        <a href="/logout" class="btn-logout"><i class="fa fa-right-from-bracket"></i> Logout</a>
      </div>
    </nav>

    <% if (typeof success !== 'undefined' && success && success.length > 0) { %>
      <div class="alert-wrap">
        <div class="alert alert-success" id="flash-msg">
          <i class="fa fa-circle-check"></i> <%= success[0] %>
        </div>
      </div>
    <% } %>
    <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
      <div class="alert-wrap">
        <div class="alert alert-error" id="flash-msg">
          <i class="fa fa-circle-exclamation"></i> <%= error[0] %>
        </div>
      </div>
    <% } %>

    <div class="page-body">
      <%- body %>
    </div>
  </div>

</div>

<!-- Delete modal -->
<div class="modal-overlay" id="deleteModal">
  <div class="modal-box">
    <div class="modal-icon"><i class="fa fa-triangle-exclamation"></i></div>
    <h3>Confirm Delete</h3>
    <p>Are you sure you want to delete this record?<br>This action <strong style="color:var(--red)">cannot be undone</strong>.</p>
    <div class="modal-actions">
      <button class="btn btn-outline btn-sm" onclick="closeModal()"><i class="fa fa-xmark"></i> Cancel</button>
      <form id="deleteForm" method="POST" style="display:inline;">
        <input type="hidden" name="_method" value="DELETE">
        <button type="submit" class="btn btn-danger btn-sm"><i class="fa fa-trash"></i> Delete</button>
      </form>
    </div>
  </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.net.min.js"></script>

<script>
  // Network bg
  if (typeof VANTA !== 'undefined') {
    VANTA.NET({
      el: '#net-canvas',
      mouseControls: false,
      touchControls: false,
      gyroControls: false,
      color: 0x3d1a6a,
      backgroundColor: 0x0e001a,
      points: 10,
      maxDistance: 22,
      spacing: 20,
    });
  }

  // Sidebar
  document.getElementById('sidebarToggle').addEventListener('click', () => {
    document.getElementById('sidebar').classList.toggle('open');
  });

  // Delete modal
  function confirmDelete(action) {
    document.getElementById('deleteForm').action = action;
    document.getElementById('deleteModal').classList.add('show');
  }
  function closeModal() {
    document.getElementById('deleteModal').classList.remove('show');
  }
  document.getElementById('deleteModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });

  // Auto-dismiss alerts
  setTimeout(() => {
    const msg = document.getElementById('flash-msg');
    if (msg) { msg.style.transition = 'opacity .5s'; msg.style.opacity = '0'; setTimeout(() => msg.remove(), 500); }
  }, 4000);
</script>

<!-- Page-specific scripts wrapped in template so they don't auto-execute -->
<template id="page-scripts"><%- script %></template>

<script>
(function () {
  var BG = '#0e001a';
  var busy = false;

  /* ── loader helpers ── */
  function loaderShow() {
    var l = document.getElementById('page-loader');
    if (l) l.style.cssText = 'display:flex;opacity:1;position:fixed;inset:0;z-index:99999;background:' + BG + ';align-items:center;justify-content:center;transition:none';
  }
  function loaderHide() {
    var l = document.getElementById('page-loader');
    if (!l) return;
    requestAnimationFrame(function () {
      l.style.transition = 'opacity .25s ease';
      l.style.opacity = '0';
      setTimeout(function () { l.style.display = 'none'; }, 260);
    });
  }

  /* ── run scripts stored in a <template> element ── */
  function runTemplate(tmpl) {
    if (!tmpl) return;
    tmpl.content.querySelectorAll('script').forEach(function (s) {
      var n = document.createElement('script');
      n.textContent = s.textContent;
      document.body.appendChild(n);
      document.body.removeChild(n);
    });
  }

  /* ── update active nav item ── */
  function updateNav(pathname) {
    document.querySelectorAll('.nav-item').forEach(function (el) {
      var h = el.getAttribute('href') || '';
      var match = h === pathname || (h !== '/' && pathname.startsWith(h));
      el.classList.toggle('active', match);
    });
  }

  /* ── re-arm auto-dismiss for flash messages ── */
  function armFlash() {
    var msg = document.getElementById('flash-msg');
    if (!msg) return;
    setTimeout(function () {
      msg.style.transition = 'opacity .5s';
      msg.style.opacity = '0';
      setTimeout(function () { msg.remove(); }, 500);
    }, 4000);
  }

  /* ── fetch-navigate: swap content without a real page load ── */
  function go(url) {
    if (busy) return;
    busy = true;
    loaderShow();

    fetch(url, { credentials: 'same-origin', headers: { 'X-Fetch-Nav': '1' } })
      .then(function (r) { return r.text(); })
      .then(function (html) {
        var doc = new DOMParser().parseFromString(html, 'text/html');

        /* title */
        document.title = doc.title;

        /* breadcrumb */
        var nb = doc.querySelector('.topbar-breadcrumb');
        var cb = document.querySelector('.topbar-breadcrumb');
        if (nb && cb) cb.innerHTML = nb.innerHTML;

        /* flash alerts */
        var na = doc.querySelector('.alert-wrap');
        var ca = document.querySelector('.alert-wrap');
        if (ca) { ca.outerHTML = na ? na.outerHTML : ''; }
        else if (na) {
          document.querySelector('.page-body').insertAdjacentHTML('beforebegin', na.outerHTML);
        }
        armFlash();

        /* page body */
        var npb = doc.querySelector('.page-body');
        var cpb = document.querySelector('.page-body');
        if (npb && cpb) cpb.innerHTML = npb.innerHTML;

        /* run page-specific scripts from template */
        var tmpl = doc.getElementById('page-scripts');
        runTemplate(tmpl);

        /* nav active */
        updateNav(new URL(url, location.href).pathname);

        history.pushState({ url: url }, document.title, url);
        busy = false;
        loaderHide();
      })
      .catch(function () {
        busy = false;
        location.href = url; // fallback: real navigation
      });
  }

  /* ── boot: run page scripts + hide loader ── */
  document.addEventListener('DOMContentLoaded', function () {
    runTemplate(document.getElementById('page-scripts'));
    loaderHide();
    armFlash();
    updateNav(location.pathname);
  });

  /* ── back / forward ── */
  window.addEventListener('popstate', function () { go(location.href); });

  /* ── click intercept ── */
  document.addEventListener('click', function (e) {
    var a = e.target.closest('a[href]');
    if (!a || a.closest('form')) return;
    var href = a.getAttribute('href') || '';
    if (!href || href === '#' || href.startsWith('javascript') || href.startsWith('mailto') || a.target === '_blank') return;
    try {
      var u = new URL(href, location.href);
      if (u.origin !== location.origin) return;
    } catch (_) { return; }
    e.preventDefault();
    go(href);
  });

  /* ── forms submit normally (server redirects after POST) ── */
  document.addEventListener('submit', loaderShow);

}());
</script>
</body>
</html>
