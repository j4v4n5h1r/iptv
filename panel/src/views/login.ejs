<!DOCTYPE html>
<html lang="en" style="background:#0e001a">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="color-scheme" content="dark">
  <title>Login — ViewNux Panel</title>
  <style>html,body{background:#0e001a!important;margin:0;padding:0}</style>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body>

<div id="net-canvas"></div>

<div class="login-page">
  <div class="login-wrap">

    <div class="login-header">
      <div class="login-icon"><i class="fa fa-tv"></i></div>
      <div class="login-title">ViewNux Panel</div>
      <div class="login-sub">Management System — Secure Access</div>
    </div>

    <div class="login-card">
      <div class="terminal-bar">
        <div class="t-dot red"></div>
        <div class="t-dot yellow"></div>
        <div class="t-dot green"></div>
        <span class="terminal-cmd"><span class="p">root@iptv:~$</span> ./authenticate --admin</span>
      </div>

      <% if (typeof error !== 'undefined' && error && error.length > 0) { %>
        <div class="alert alert-error" style="margin-bottom:18px;">
          <i class="fa fa-circle-exclamation"></i> <%= error[0] %>
        </div>
      <% } %>

      <form method="POST" action="/login">
        <div class="form-group">
          <label class="form-label"><span class="prompt">--</span> Username</label>
          <input type="text" name="username" class="form-control" placeholder="admin" autocomplete="username" required>
        </div>
        <div class="form-group">
          <label class="form-label"><span class="prompt">--</span> Password</label>
          <input type="password" name="password" class="form-control" placeholder="••••••••" autocomplete="current-password" required>
        </div>
        <button type="submit" class="btn-login">
          <i class="fa fa-terminal"></i> &nbsp;[ AUTHENTICATE ]
        </button>
      </form>
    </div>

  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/vanta@latest/dist/vanta.net.min.js"></script>
<script>
  if (typeof VANTA !== 'undefined') {
    VANTA.NET({
      el: '#net-canvas',
      mouseControls: true,
      touchControls: true,
      gyroControls: false,
      color: 0x7c3aed,
      backgroundColor: 0x0e001a,
      points: 12,
      maxDistance: 25,
      spacing: 18,
    });
  }
</script>
<script>
window.addEventListener('pagehide', function() {
  document.documentElement.style.background = '#0e001a';
  document.body.style.background = '#0e001a';
});
document.addEventListener('submit', function() {
  document.documentElement.style.background = '#0e001a';
  document.body.style.background = '#0e001a';
});
</script>
</body>
</html>
