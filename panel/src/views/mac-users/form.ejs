<div class="page-header">
  <h1 class="page-title">
    <span class="prompt">$</span> <%= user ? 'edit-user' : 'add-user' %>
  </h1>
  <a href="/mac-users" class="btn btn-outline"><i class="fa fa-arrow-left"></i> Back</a>
</div>

<div class="card" style="max-width:640px;">
  <div class="card-header">
    <span class="card-title">// <%= user ? 'Edit App User' : 'New App User' %></span>
  </div>
  <div class="card-body">
    <form method="POST" action="<%= user ? '/mac-users/' + user.id : '/mac-users' %>">
      <% if (user) { %><input type="hidden" name="_method" value="POST"><% } %>

      <!-- M3U Extractor -->
      <div class="form-group">
        <label class="form-label"><span class="prompt">--</span> M3U Extractor URL <span style="color:var(--text-muted); font-size:14px;">(optional)</span></label>
        <div style="display:flex; gap:8px;">
          <input type="text" id="m3u_address" name="m3u_address" class="form-control"
            placeholder="http://server:port/get.php?username=xxx&password=xxx&type=m3u"
            value="<%= user && user.m3u_address ? user.m3u_address : '' %>">
          <button type="button" class="btn btn-outline" onclick="extractM3U()" style="white-space:nowrap; flex-shrink:0;">
            <i class="fa fa-wand-magic-sparkles"></i> Extract
          </button>
        </div>
        <div class="form-hint">Paste an M3U URL to auto-fill fields below.</div>
      </div>

      <div class="form-group">
        <label class="form-label"><span class="prompt">--</span> Title / Name</label>
        <input type="text" name="title" id="field-title" class="form-control" placeholder="e.g. John Doe"
          value="<%= user ? user.title : '' %>" required>
      </div>

      <!-- App Keys -->
      <div class="form-group">
        <label class="form-label">
          <span class="prompt">--</span> App Keys
          <span style="color:var(--text-muted);font-size:13px;">(müşterinin her TV'sinden gelen key)</span>
        </label>
        <div id="appKeyList" style="display:flex; flex-direction:column; gap:8px; margin-bottom:8px;">
          <% const existingKeys = user ? (userAppKeys || [user.app_key]).filter(Boolean) : ['']; %>
          <% existingKeys.forEach((k, idx) => { %>
            <div class="key-row">
              <input type="text" name="app_keys[]" class="form-control"
                placeholder="VNUX-XXXX-XXXX" value="<%= k %>"
                style="font-family:monospace; letter-spacing:1.5px; text-transform:uppercase;"
                oninput="this.value=this.value.toUpperCase()"
                <%= idx === 0 && !user ? 'required' : '' %>>
              <% if (idx > 0) { %>
                <button type="button" class="btn btn-danger btn-sm" onclick="this.parentElement.remove()">
                  <i class="fa fa-trash"></i>
                </button>
              <% } %>
            </div>
          <% }) %>
        </div>
        <button type="button" class="btn btn-outline btn-sm" onclick="addKeyRow()">
          <i class="fa fa-plus"></i> App Key Ekle
        </button>
        <div class="form-hint">Her TV için müşteri kendi cihazında görünen App Key'i size gönderir.</div>
      </div>

      <input type="hidden" name="protection" value="NO">

      <div class="grid-2">
        <div class="form-group">
          <label class="form-label"><span class="prompt">--</span> Username</label>
          <input type="text" name="username" id="field-username" class="form-control"
            placeholder="stream username"
            value="<%= user ? user.username : '' %>" required>
        </div>
        <div class="form-group">
          <label class="form-label"><span class="prompt">--</span> Password</label>
          <input type="text" name="password" id="field-password" class="form-control"
            placeholder="stream password"
            value="<%= user ? user.password : '' %>" required>
        </div>
      </div>

      <div class="form-group">
        <label class="form-label"><span class="prompt">--</span> Server URL</label>
        <input type="text" name="server_url" id="field-server-url" class="form-control"
          placeholder="http://yourserver.com"
          value="<%= user && user.server_url ? user.server_url : '' %>">
        <div class="form-hint">e.g. http://yourserver.com:8080</div>
      </div>

      <button type="submit" class="btn btn-primary">
        <i class="fa fa-save"></i> <%= user ? 'Update User' : 'Create User' %>
      </button>
    </form>
  </div>
</div>

<style>
.key-row { display:flex; gap:8px; align-items:center; }
.key-row input { flex:1; }
</style>

<script>
function addKeyRow() {
  const list = document.getElementById('appKeyList');
  const row = document.createElement('div');
  row.className = 'key-row';
  row.innerHTML = `
    <input type="text" name="app_keys[]" class="form-control"
      placeholder="VNUX-XXXX-XXXX"
      style="font-family:monospace; letter-spacing:1.5px; text-transform:uppercase;"
      oninput="this.value=this.value.toUpperCase()">
    <button type="button" class="btn btn-danger btn-sm" onclick="this.parentElement.remove()">
      <i class="fa fa-trash"></i>
    </button>`;
  list.appendChild(row);
  row.querySelector('input').focus();
}

function extractM3U() {
  const url = document.getElementById('m3u_address').value.trim();
  if (!url) { alert('Please paste an M3U URL first.'); return; }
  try {
    const u = new URL(url);
    const un = u.searchParams.get('username');
    const pw = u.searchParams.get('password');
    if (un) document.getElementById('field-username').value = un;
    if (pw) document.getElementById('field-password').value = pw;
    if (un || pw) {
      document.getElementById('field-username').style.borderColor = 'var(--green)';
      document.getElementById('field-password').style.borderColor = 'var(--green)';
    }
  } catch(e) {
    alert('Could not parse URL. Please enter a valid M3U URL.');
  }
}
</script>
