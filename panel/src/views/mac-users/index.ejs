<div class="page-header">
  <h1 class="page-title"><span class="prompt">$</span> app-users</h1>
  <a href="/mac-users/create" class="btn btn-primary"><i class="fa fa-plus"></i> Add User</a>
</div>

<div class="stats-row">
  <div class="stat-card">
    <div class="stat-label">Total Users</div>
    <div class="stat-value"><%= users.length %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Protected</div>
    <div class="stat-value green"><%= users.filter(u => u.protection === 'YES').length %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Unprotected</div>
    <div class="stat-value red"><%= users.filter(u => u.protection === 'NO').length %></div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <span class="card-title">// Current Users</span>
  </div>
  <div class="card-body">
    <% if (users.length === 0) { %>
      <div class="empty-state">
        <span class="ei"><i class="fa fa-microchip"></i></span>
        <p>No users yet. <a href="/mac-users/create">Add your first user</a>.</p>
      </div>
    <% } else { %>
      <div class="table-wrapper">
        <table id="macTable" class="display" style="width:100%">
          <thead>
            <tr>
              <th>#</th>
              <th>Title</th>
              <th>App Key</th>
              <th>Username</th>
              <th>Protected</th>
              <th>Server</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach((u, i) => { %>
              <tr>
                <td class="td-code"><%= i + 1 %></td>
                <td><strong><%= u.title %></strong></td>
                <td class="td-code" style="color:var(--green); letter-spacing:1.5px"><%= u.app_key %></td>
                <td class="td-code"><%= u.username %></td>
                <td><span class="badge badge-<%= u.protection.toLowerCase() %>"><%= u.protection %></span></td>
                <td class="td-code" style="font-size:14px"><%= u.server_title || '—' %></td>
                <td>
                  <a href="/mac-users/<%= u.id %>/edit" class="btn btn-outline btn-sm"><i class="fa fa-pen"></i> Edit</a>
                  &nbsp;
                  <a href="/trials/create?mac=<%= encodeURIComponent(u.app_key) %>" class="btn btn-green btn-sm"><i class="fa fa-calendar"></i> Trial</a>
                  &nbsp;
                  <button class="btn btn-danger btn-sm" onclick="confirmDelete('/mac-users/<%= u.id %>?_method=DELETE')">
                    <i class="fa fa-trash"></i>
                  </button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<!-- Generate Activation Code -->
<div class="card mb-20" style="margin-top:32px">
  <div class="card-header">
    <span class="card-title">// Generate Activation Code</span>
  </div>
  <div class="card-body">
    <form method="POST" action="/activation-codes" style="display:flex; gap:14px; flex-wrap:wrap; align-items:flex-end;">
      <div class="form-group" style="margin:0; flex:1; min-width:220px;">
        <label class="form-label"><span class="prompt">--</span> App User</label>
        <select name="mac_user_id" class="form-control" id="macUserSelect" onchange="onMacUserChange(this)">
          <option value="">— No specific user —</option>
          <% macUsers.forEach(u => { %>
            <option value="<%= u.id %>"><%= u.title %> (<%= u.app_key %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="form-group" style="margin:0; width:110px;">
        <label class="form-label"><span class="prompt">--</span> Count</label>
        <input type="number" name="count" class="form-control" value="1" min="1" max="50">
      </div>
      <button type="submit" class="btn btn-primary" style="margin-bottom:0;">
        <i class="fa fa-bolt"></i> Generate
      </button>
    </form>
  </div>
</div>

<!-- Activation Codes List -->
<div class="card">
  <div class="card-header">
    <span class="card-title">// Activation Codes</span>
  </div>
  <div class="card-body">
    <% if (codes.length === 0) { %>
      <div class="empty-state">
        <span class="ei"><i class="fa fa-key"></i></span>
        <p>No activation codes yet. Generate some above.</p>
      </div>
    <% } else { %>
      <div class="table-wrapper">
        <table id="actTable" class="display" style="width:100%">
          <thead>
            <tr>
              <th>#</th>
              <th>Activation Code</th>
              <th>Status</th>
              <th>Used By (App Key)</th>
              <th>Server</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% codes.forEach((c, i) => { %>
              <tr>
                <td class="td-code"><%= i + 1 %></td>
                <td class="td-code" style="color:var(--green); letter-spacing:1px; font-size:15px">
                  <b><%= c.code %></b>
                  <button class="btn-copy" title="Copy code" onclick="copyCode(this, '<%= c.code %>')">
                    <i class="fa fa-copy"></i>
                  </button>
                </td>
                <td><span class="badge badge-<%= c.status %>"><%= c.status %></span></td>
                <td class="td-code"><%= c.used_by || '—' %></td>
                <td class="td-code"><%= c.server_title || '—' %></td>
                <td class="td-code"><%= c.created_at ? c.created_at.split('T')[0] : '—' %></td>
                <td>
                  <% if (c.status === 'used') { %>
                    <form method="POST" action="/activation-codes/<%= c.id %>/reset" style="display:inline;">
                      <button type="submit" class="btn btn-outline btn-sm"><i class="fa fa-rotate-left"></i> Reset</button>
                    </form>
                    &nbsp;
                  <% } %>
                  <button class="btn btn-danger btn-sm" onclick="confirmDelete('/activation-codes/<%= c.id %>?_method=DELETE')">
                    <i class="fa fa-trash"></i>
                  </button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<style>
.btn-copy {
  background: none; border: none; color: var(--text-muted); cursor: pointer;
  padding: 2px 5px; margin-left: 6px; border-radius: 3px; font-size: 14px;
  transition: color .15s; vertical-align: middle;
}
.btn-copy:hover { color: var(--green); }
.btn-copy.copied { color: var(--green); }
</style>

<script>
$(document).ready(function() {
  $('#macTable').DataTable({
    lengthMenu: [[10, 25, 50, -1], [10, 25, 50, 'All']],
    order: [],
    columnDefs: [{ orderable: false, targets: 6 }],
    language: { search: '<i class="fa fa-search"></i>', searchPlaceholder: 'Search users...' }
  });
  $('#actTable').DataTable({
    lengthMenu: [[10, 25, 50, -1], [10, 25, 50, 'All']],
    order: [[5, 'desc']],
    columnDefs: [{ orderable: false, targets: 6 }],
    language: { search: '<i class="fa fa-search"></i>', searchPlaceholder: 'Search codes...' }
  });
});

function onMacUserChange(sel) {
  const countInput = sel.closest('form').querySelector('[name="count"]');
  if (sel.value) { countInput.value = 1; countInput.disabled = true; }
  else { countInput.disabled = false; }
}

function copyCode(btn, code) {
  navigator.clipboard.writeText(code).then(() => {
    const icon = btn.querySelector('i');
    icon.className = 'fa fa-check';
    btn.classList.add('copied');
    setTimeout(() => { icon.className = 'fa fa-copy'; btn.classList.remove('copied'); }, 1500);
  });
}
</script>
