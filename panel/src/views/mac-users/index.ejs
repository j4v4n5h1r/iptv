<div class="page-header">
  <h1 class="page-title"><span class="prompt">$</span> mac-users</h1>
  <a href="/mac-users/create" class="btn btn-primary"><i class="fa fa-plus"></i> Add User</a>
</div>

<div class="stats-row">
  <div class="stat-card">
    <div class="stat-label">Total Users</div>
    <div class="stat-value"><%= users.length %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Protected</div>
    <div class="stat-value green"><%= users.filter(u => u.protection === 'YES').length %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Unprotected</div>
    <div class="stat-value red"><%= users.filter(u => u.protection === 'NO').length %></div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <span class="card-title">// Current Users</span>
  </div>
  <div class="card-body">
    <% if (users.length === 0) { %>
      <div class="empty-state">
        <span class="ei"><i class="fa fa-microchip"></i></span>
        <p>No MAC users yet. <a href="/mac-users/create">Add your first user</a>.</p>
      </div>
    <% } else { %>
      <div class="table-wrapper">
        <table id="macTable" class="display" style="width:100%">
          <thead>
            <tr>
              <th>#</th>
              <th>Title</th>
              <th>MAC Address</th>
              <th>Username</th>
              <th>Protected</th>
              <th>Server</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach((u, i) => { %>
              <tr>
                <td class="td-code"><%= i + 1 %></td>
                <td><strong><%= u.title %></strong></td>
                <td class="td-code" style="color:var(--green); letter-spacing:.5px"><%= u.mac_address %></td>
                <td class="td-code"><%= u.username %></td>
                <td><span class="badge badge-<%= u.protection.toLowerCase() %>"><%= u.protection %></span></td>
                <td class="td-code" style="font-size:14px"><%= u.server_title || '—' %></td>
                <td>
                  <a href="/mac-users/<%= u.id %>/edit" class="btn btn-outline btn-sm"><i class="fa fa-pen"></i> Edit</a>
                  &nbsp;
                  <a href="/trials/create?mac=<%= encodeURIComponent(u.mac_address) %>" class="btn btn-green btn-sm"><i class="fa fa-calendar"></i> Trial</a>
                  &nbsp;
                  <button class="btn btn-danger btn-sm" onclick="confirmDelete('/mac-users/<%= u.id %>?_method=DELETE')">
                    <i class="fa fa-trash"></i>
                  </button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<script>
$(document).ready(function() {
  $('#macTable').DataTable({
    lengthMenu: [[10, 25, 50, -1], [10, 25, 50, 'All']],
    order: [],
    columnDefs: [{ orderable: false, targets: 6 }],
    language: { search: '<i class="fa fa-search"></i>', searchPlaceholder: 'Search users...' }
  });
});
</script>
