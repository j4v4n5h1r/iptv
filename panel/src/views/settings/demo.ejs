<div class="page-header">
  <h1 class="page-title"><span class="prompt">$</span> set-demo</h1>
</div>

<div class="card" style="max-width:580px;">
  <div class="card-header">
    <span class="card-title">// Setup Demo Playlist</span>
  </div>
  <div class="card-body">
    <p class="text-muted" style="font-size:15px; margin-bottom:20px; line-height:1.7;">
      These credentials are served to the Flutter app as a demo/trial playlist for unregistered users.<br>
      Leave blank to disable the demo mode.
    </p>
    <form method="POST" action="/settings/demo">
      <div class="form-group">
        <label class="form-label"><span class="prompt">--</span> Playlist Name</label>
        <input type="text" name="playlist_name" class="form-control" placeholder="e.g. Demo TV" value="<%= demo.playlist_name %>">
      </div>
      <div class="form-group">
        <label class="form-label"><span class="prompt">--</span> DNS / Server URL</label>
        <input type="text" name="dns" class="form-control" placeholder="http://demo.server.com:8080" value="<%= demo.dns %>">
      </div>
      <div class="grid-2">
        <div class="form-group">
          <label class="form-label"><span class="prompt">--</span> Username</label>
          <input type="text" name="username" class="form-control" placeholder="demo_user" value="<%= demo.username %>">
        </div>
        <div class="form-group">
          <label class="form-label"><span class="prompt">--</span> Password</label>
          <input type="text" name="password" class="form-control" placeholder="demo_pass" value="<%= demo.password %>">
        </div>
      </div>
      <button type="submit" class="btn btn-primary">
        <i class="fa fa-save"></i> Save Demo Settings
      </button>
    </form>
  </div>
</div>
