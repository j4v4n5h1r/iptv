<div class="page-header">
  <h1 class="page-title"><span class="prompt">$</span> license-key</h1>
</div>

<div class="card" style="max-width:500px;">
  <div class="card-header">
    <span class="card-title">// License Key</span>
  </div>
  <div class="card-body">
    <div class="alert <%= hasKey ? 'alert-success' : 'alert-error' %>" style="margin-bottom:20px;">
      <i class="fa <%= hasKey ? 'fa-circle-check' : 'fa-circle-xmark' %>"></i>
      <span><strong>Status:</strong> <%= hasKey ? '✅ License key is configured' : '❌ No license key set' %></span>
    </div>
    <p class="text-muted" style="font-size:15px; margin-bottom:20px; line-height:1.7;">
      The license key is stored securely and is never displayed.<br>
      Only enter a new key to overwrite the existing one. Leave blank to keep current.
    </p>
    <form method="POST" action="/settings/license">
      <div class="form-group">
        <label class="form-label"><span class="prompt">--</span> License Key</label>
        <input type="password" name="license_key" class="form-control" placeholder="Paste your license key here" autocomplete="off">
      </div>
      <button type="submit" class="btn btn-primary"><i class="fa fa-save"></i> Save License Key</button>
    </form>
  </div>
</div>
