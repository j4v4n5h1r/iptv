<div class="page-header">
  <h1 class="page-title"><span class="prompt">$</span> set-notification</h1>
</div>

<div class="card" style="max-width:580px;">
  <div class="card-header">
    <span class="card-title">// App Notification</span>
  </div>
  <div class="card-body">
    <p class="text-muted" style="font-size:15px; margin-bottom:20px; line-height:1.7;">
      This notification is shown to users when they open the app.<br>
      Leave both fields blank to hide the notification.
    </p>
    <form method="POST" action="/settings/notification">
      <div class="form-group">
        <label class="form-label"><span class="prompt">--</span> Title</label>
        <input type="text" name="notif_title" class="form-control" placeholder="e.g. System Maintenance" value="<%= notif.title %>">
      </div>
      <div class="form-group">
        <label class="form-label"><span class="prompt">--</span> Content</label>
        <textarea name="notif_content" class="form-control" rows="5" placeholder="Write your notification message here..."><%= notif.content %></textarea>
      </div>
      <button type="submit" class="btn btn-primary">
        <i class="fa fa-save"></i> Save Notification
      </button>
    </form>
  </div>
</div>
