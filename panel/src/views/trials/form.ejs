<div class="page-header">
  <h1 class="page-title">
    <span class="prompt">$</span> <%= trial ? 'edit-expiration' : 'set-expiration' %>
  </h1>
  <a href="/trials" class="btn btn-outline"><i class="fa fa-arrow-left"></i> Back</a>
</div>

<div class="card" style="max-width:480px;">
  <div class="card-header">
    <span class="card-title">// <%= trial ? 'Edit Expiry Date' : 'Set Expiry Date' %></span>
  </div>
  <div class="card-body">
    <form method="POST" action="<%= trial ? '/trials/' + trial.id : '/trials' %>">

      <div class="form-group">
        <label class="form-label"><span class="prompt">--</span> MAC Address</label>
        <input type="text" name="mac_address" class="form-control"
          placeholder="AA:BB:CC:DD:EE:FF"
          value="<%= mac || (trial ? trial.mac_address : '') %>"
          style="text-transform:uppercase; letter-spacing:.5px;"
          required>
      </div>

      <div class="form-group">
        <label class="form-label"><span class="prompt">--</span> Expire Date</label>
        <input type="date" name="expire_date" class="form-control"
          value="<%= trial ? trial.expire_date : '' %>" required>
      </div>

      <button type="submit" class="btn btn-primary">
        <i class="fa fa-save"></i> <%= trial ? 'Update Expiry' : 'Set Expiry' %>
      </button>
    </form>
  </div>
</div>
