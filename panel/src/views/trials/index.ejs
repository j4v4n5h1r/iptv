<div class="page-header">
  <h1 class="page-title"><span class="prompt">$</span> set-expiration</h1>
  <a href="/trials/create" class="btn btn-primary"><i class="fa fa-plus"></i> Set Expiry</a>
</div>

<div class="stats-row">
  <div class="stat-card">
    <div class="stat-label">Total Trials</div>
    <div class="stat-value"><%= trials.length %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Active</div>
    <div class="stat-value green"><%= trials.filter(t => t.expire_date >= today).length %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Expired</div>
    <div class="stat-value red"><%= trials.filter(t => t.expire_date < today).length %></div>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <span class="card-title">// Current Trials</span>
  </div>
  <div class="card-body">
    <% if (trials.length === 0) { %>
      <div class="empty-state">
        <span class="ei"><i class="fa fa-calendar-days"></i></span>
        <p>No trials configured. <a href="/trials/create">Set an expiry date</a>.</p>
      </div>
    <% } else { %>
      <div class="table-wrapper">
        <table id="trialsTable" class="display" style="width:100%">
          <thead>
            <tr>
              <th>#</th>
              <th>Title</th>
              <th>MAC Address</th>
              <th>Expire Date</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% trials.forEach((t, i) => { %>
              <% const expired = t.expire_date < today; %>
              <tr>
                <td class="td-code"><%= i + 1 %></td>
                <td><strong><%= t.user_title || '—' %></strong></td>
                <td class="td-code" style="color:var(--green)"><%= t.mac_address %></td>
                <td class="td-code" style="color:<%= expired ? 'var(--red)' : 'var(--green)' %>">
                  <b><%= t.expire_date %></b>
                </td>
                <td>
                  <span class="badge <%= expired ? 'badge-used' : 'badge-unused' %>">
                    <%= expired ? 'expired' : 'active' %>
                  </span>
                </td>
                <td>
                  <a href="/trials/<%= t.id %>/edit" class="btn btn-outline btn-sm"><i class="fa fa-pen"></i> Edit</a>
                  &nbsp;
                  <button class="btn btn-danger btn-sm" onclick="confirmDelete('/trials/<%= t.id %>?_method=DELETE')">
                    <i class="fa fa-trash"></i>
                  </button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>

<script>
$(document).ready(function() {
  $('#trialsTable').DataTable({
    lengthMenu: [[10, 25, 50, -1], [10, 25, 50, 'All']],
    order: [[2, 'asc']],
    columnDefs: [{ orderable: false, targets: 5 }],
    language: { search: '<i class="fa fa-search"></i>', searchPlaceholder: 'Search...' }
  });
});
</script>
